@startuml
title Plano de Voo - Componentes e Interfaces

skinparam shadowing false
skinparam componentStyle rectangle
skinparam linetype ortho

package "Frontend" {
  [site/planodevoo/index.html] as c_site
  [site/gerar-plano-voo/index.html] as c_app_entry
}

package "Cloudflare Workers" {
  [api-precheckout] as c_pre
  [links-redirect] as c_links
  [api-external-webhooks] as c_ingress
  [api-events-consumer] as c_consumer
}

package "Cloudflare Data Plane" {
  [decole-q-hotmart-events] as c_queue
  [decole-q-hotmart-events-dlq] as c_dlq
  [DEDUPE_KV] as c_kv
}

package "External Systems" {
  [Hotmart] as c_hotmart
  [Brevo] as c_brevo
  [n8n] as c_n8n
}

interface "I_Precheckout\nPOST /brevo" as I_PRE
interface "I_LinksCheckout\nGET /plano-de-voo/checkout" as I_LINKS
interface "I_WebhookIngress\nPOST /webhooks/v1/{produto}/{subsistema}/{operacao}" as I_ING
interface "I_HotmartLegacy\nPOST /webhooks/hotmart" as I_ING_LEGACY
interface "I_QueueHotmartEvents\nenqueue/dequeue" as I_QUEUE
interface "I_BrevoContacts\nDOI + update attributes" as I_BREVO
interface "I_N8N_Hotmart\nPOST /webhook/plano-de-voo/hotmart" as I_N8N_HOT
interface "I_N8N_AppSubmit\nPOST /webhook/plano-de-voo/submeter" as I_N8N_SUB
interface "I_N8N_Validate\nGET /webhook/validar-token" as I_N8N_VAL

c_site ..> I_PRE
I_PRE - c_pre
c_site ..> I_LINKS
I_LINKS - c_links

c_hotmart ..> I_ING
I_ING - c_ingress
c_hotmart ..> I_ING_LEGACY
I_ING_LEGACY - c_ingress

c_ingress ..> I_N8N_HOT
I_N8N_HOT - c_n8n
c_ingress ..> I_QUEUE
I_QUEUE - c_queue

c_queue ..> I_QUEUE
I_QUEUE - c_consumer

c_consumer ..> I_BREVO
I_BREVO - c_brevo
c_pre ..> I_BREVO

c_consumer --> c_kv : dedupe get/put
c_consumer --> c_dlq : retries exhausted

c_app_entry ..> I_N8N_VAL
I_N8N_VAL - c_n8n
c_app_entry ..> I_N8N_SUB
I_N8N_SUB - c_n8n

note right of c_pre
Config interface:
- PRECHECKOUT_PRODUCTS
- product_code -> listId + doiTemplateId
end note

note right of c_ingress
Config interface:
- HOTMART_WEBHOOK_TOKEN
- WEBHOOK_FORWARDING_RULES
end note

note right of c_consumer
Config interface:
- HOTMART_PRODUCTS
- BREVO_CART_ABANDONMENT_TEMPLATE_ID
- BREVO_REPLY_TO_EMAIL
end note

@enduml
