  "workerViews": {
    "api-hotmart-ingress": {
      "description": "Recebe webhooks Hotmart, normaliza para FunnelEvent e publica na queue canônica.",
      "secrets": [
        "HOTMART_WEBHOOK_TOKEN"
      ]
    },
    "api-funnel-ingress": {
      "description": "Recebe eventos de precheckout/browser/app e publica na queue canônica.",
      "secrets": [
        "APP_EVENTS_HMAC"
      ]
    },
    "funnel-dispatcher": {
      "description": "Consome queue canônica e executa chain por evento/produto com dedupe event_id:handler.",
      "bindings": [
        "DEDUPE_KV",
        "IDENTITY_KV",
        "IDENTITY_DB",
        "EVENT_STORE_DB"
      ],
      "secrets": [
        "BREVO_API_KEY",
        "BREVO_DOI_TEMPLATE_ID",
        "BREVO_CART_ABANDONMENT_TEMPLATE_ID",
        "N8N_WEBHOOK_URL",
        "SGTM_ENDPOINT_URL",
        "SGTM_ENDPOINT_URL_DECOLE_ESG",
        "SGTM_ENDPOINT_URL_PLANOVOO",
        "BREVO_SANDBOX",
        "N8N_DISABLE_FORWARD"
      ]
    },
    "api-precheckout": {
      "description": "Lead capture que publica GENERATE_LEAD na queue; o funnel-dispatcher executa DOI nativo Brevo por produto.",
      "derivedConfig": "Para cada produto → {code, aliases, listId: brevo.lists.precheckout.id, doiTemplateId: brevo.templates.doi.id, doiRedirectUrl}"
    },
    "links-redirect": {
      "description": "Redirects de checkout. Emite BEGIN_CHECKOUT antes do redirect para a Hotmart.",
      "envVarMapping": {
        "LINKS_PRODUCTS": "Para cada produto → {checkoutPath, checkoutBaseUrl, productCode}",
        "FUNNEL_EVENTS": "Fila canônica para BEGIN_CHECKOUT",
        "DECOLE_MENTORIA_CHECKOUT_URL": "products.DECOLE_ESG_MENTORIA.links.checkoutBaseUrl",
        "PLANO_DE_VOO_CHECKOUT_URL": "products.DECOLE_PLANOVOO.links.checkoutBaseUrl"
      }
    }
  },
  "funnelStages": {
    "AWARENESS": {
      "order": 1,
      "goal": "visit"
    },
    "CONSIDERATION": {
      "order": 2,
      "goal": "engage"
    },
    "CONVERSION": {
      "order": 3,
      "goal": "checkout"
    },
    "PURCHASE": {
      "order": 4,
      "goal": "approved"
    },
    "ACTIVATION": {
      "order": 5,
      "goal": "first_use"
    },
    "RETENTION": {
      "order": 6,
      "goal": "repeat_use"
    }
  },
  "handlers": {
    "resolve_identity": {
      "worker": "funnel-dispatcher",
      "bindings": [
        "IDENTITY_KV",
        "IDENTITY_DB"
      ]
    },
    "upsert_event_store": {
      "worker": "funnel-dispatcher",
      "binding": "EVENT_STORE_DB"
    },
    "send_brevo_doi": {
      "worker": "funnel-dispatcher",
      "binding": "BREVO_API_KEY",
      "endpoint": "/contacts/doubleOptinConfirmation"
    },
    "update_brevo_funnel": {
      "worker": "funnel-dispatcher",
      "binding": "BREVO_API_KEY"
    },
    "send_cart_abandonment_email": {
      "worker": "funnel-dispatcher",
      "binding": "BREVO_API_KEY",
      "endpoint": "/smtp/email"
    },
    "forward_n8n": {
      "worker": "funnel-dispatcher",
      "binding": "N8N_WEBHOOK_URL"
    },
    "enrich_attribution": {
      "worker": "funnel-dispatcher",
      "binding": "EVENT_STORE_DB",
      "note": "Enriches hotmart events with fbp/fbc/client_ip from most recent site event for same profile"
    },
    "emit_tracking": {
      "worker": "funnel-dispatcher",
      "status": "active_via_sgtm",
      "bindings": [
        "SGTM_ENDPOINT_URL",
        "SGTM_ENDPOINT_URL_DECOLE_ESG",
        "SGTM_ENDPOINT_URL_PLANOVOO"
      ]
    },
    "sync_brevo_segments": {
      "worker": "funnel-dispatcher",
      "binding": "BREVO_API_KEY"
    }
  }
}
