@startuml funil-mkt-platform-architecture
' ─── Theme & layout ──────────────────────────────────────────────────────────
top to bottom direction
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #FFFFFF
skinparam ArrowColor #555555
skinparam ArrowThickness 1.2
skinparam componentStyle rectangle
skinparam RoundCorner 6
skinparam Padding 5
skinparam nodesep 35
skinparam ranksep 45

skinparam package {
  BackgroundColor #F8F9FA
  BorderColor     #AAAAAA
  FontStyle       bold
  FontSize        11
}
skinparam component {
  BackgroundColor #FFFFFF
  BorderColor     #888888
  FontSize        10
}
skinparam database {
  BackgroundColor #E8F5E9
  BorderColor     #388E3C
  FontSize        10
}
skinparam queue {
  BackgroundColor #F3E5F5
  BorderColor     #7B1FA2
  FontSize        10
}
skinparam actor {
  BackgroundColor #E3F2FD
  BorderColor     #1565C0
  FontSize        10
}
skinparam note {
  BackgroundColor #FFFDE7
  BorderColor     #F9A825
  FontSize        9
}

' ════════════════════════════════════════════════════════════════
'  LEGEND — delivery types
' ════════════════════════════════════════════════════════════════
legend top left
  <b>Event delivery types (products.catalog.json)</b>
  |= delivery |= who fires |= tracking |= server funnel |
  | <color:#1565C0>gtm_web_only</color>  | browser only   | GTM Web → sGTM → GA4 + Meta CAPI  | ✗ no queue |
  | <color:#2E7D32>both (gtm_web_to_sgtm)</color> | browser + server | GTM Web → sGTM → GA4 + Meta CAPI | ✓ queue (emit_tracking <b>skipped</b> server-side — ex: GENERATE_LEAD) |
  | <color:#6A1B9A>server_queue</color>  | server only | emit_tracking → sGTM | ✓ full chain (ex: PURCHASE_APPROVED, SIGN_UP) |
endlegend

' ════════════════════════════════════════════════════════════════
'  LAYER 0 — Config (bundled at build time)
' ════════════════════════════════════════════════════════════════
package "Config — bundled into every worker at build time" as config_pkg #FFFDE7 {
  component "products.catalog.json\n──────────────────────────────\ntenants · products · hotmart IDs\nevents · delivery type · chain[]\ntracking · links · brevo config\nlandingPages · GTM container IDs\nintegrations (n8n, planovoo)" as catalog #FFF9C4
}

' ════════════════════════════════════════════════════════════════
'  LAYER 1 — Static Site + Landing Pages
' ════════════════════════════════════════════════════════════════
package "Static Site  (decolesuacarreiraesg.com.br)" as site_pkg #E8F4FD {

  package "DECOLE ESG Mentoria" as lp_esg_pkg #DBEAFE {
    component "/  ·  /bio-insta.html\n─────────────────────\n<color:#1565C0>page_view</color>  →  ga4_via_gtm + pixel_via_gtm\n<color:#1565C0>cta_click</color>  →  ga4_via_gtm + pixel_via_gtm\n<color:#2E7D32>generate_lead</color>  →  ga4_via_gtm + pixel_via_gtm\n             + api-precheckout (server)" as lp_esg #BFDBFE
    component "/confirmacao.html  (DOI)\n─────────────────────\n<color:#1565C0>page_view</color>  →  ga4_via_gtm\n<i>sem conversao browser-side</i>\n<i>SIGN_UP emitido via links-redirect</i>" as lp_esg_doi #BFDBFE
  }

  package "DECOLE Plano de Voo" as lp_pv_pkg #DBEAFE {
    component "/planodevoo\n─────────────────────\n<color:#1565C0>page_view</color>  →  ga4_via_gtm + pixel_via_gtm\n<color:#1565C0>cta_click</color>  →  ga4_via_gtm + pixel_via_gtm\n<color:#2E7D32>generate_lead</color>  →  ga4_via_gtm + pixel_via_gtm\n             + api-precheckout (server)" as lp_pv #BFDBFE
    component "/planodevoo/confirmacao.html  (DOI)\n─────────────────────\n<color:#1565C0>page_view</color>  →  ga4_via_gtm\n<i>sem conversao browser-side</i>\n<i>SIGN_UP emitido via links-redirect</i>" as lp_pv_doi #BFDBFE
  }

  component "GTM Web Container  GTM-58CQ9K7X\n─────────────────────────────────────────\nreceives dataLayer events\nGA4 tag  →  sGTM  (sends <b>produto</b> param)\nMeta Pixel tag  →  sGTM  (sends <b>pixel_id</b> param)\n─────────────────────────────────────────\n<b>produto</b>  differentiationKey per product:\n  ESG Mentoria  →  produto=DECOLE_ESG_MENTORIA\n  Plano de Voo  →  produto=DECOLE_PLANOVOO" as gtm_web #93C5FD
}

actor "Browser / User" as browser #D6EAF8

' ════════════════════════════════════════════════════════════════
'  LAYER 2 — Hotmart
' ════════════════════════════════════════════════════════════════
actor "Hotmart" as hotmart #FAE5D3

' ════════════════════════════════════════════════════════════════
'  LAYER 3 — Ingress workers
' ════════════════════════════════════════════════════════════════
package "Ingress Layer  (Cloudflare Workers)" as ingress_pkg #E8EAED {
  component "api-hotmart-ingress\n· validate hottok (Secrets Store)\n· resolve tenant + product (catalog)\n· normalize → FunnelEvent\n· publish to Queue" as hw #CFD8DC

  component "api-funnel-ingress\n· CORS from catalog allowedOrigins\n· HMAC validation (app webhooks)\n· publish to Queue" as fw #CFD8DC

  component "api-precheckout\n· lead form capture\n· resolve DOI config → catalog\n· emit GENERATE_LEAD" as pw #CFD8DC

  component "links-redirect\n· resolve route → catalog\n· emit BEGIN_CHECKOUT to Queue\n· emit SIGN_UP to Queue (DOI links)\n· 302 → checkout URL / confirmacao.html" as lr #CFD8DC
}

' ════════════════════════════════════════════════════════════════
'  LAYER 4 — Queue
' ════════════════════════════════════════════════════════════════
queue "decole-q-funnel-events  (Cloudflare Queue)\nbatch 25 · timeout 10 s · max_retries 5" as q
queue "Dead Letter Queue\n(max_retries exceeded)" as dlq #FCE4EC

' ════════════════════════════════════════════════════════════════
'  LAYER 5 — Dispatcher
' ════════════════════════════════════════════════════════════════
package "funnel-dispatcher  (Cloudflare Queue Consumer)" as disp_pkg #F1F8E9 {

  component "resolveChain(event, catalog)\n→ chain[ ] from catalog event config\nor DEFAULT_CHAIN_MAP fallback" as resolve #DCEDC8

  package "Per-handler DEDUPE guard" as dedupe_pkg #FAFAFA {
    component "GET  tenant:product:event_id:handler\n─ skip (restore result) if exists ─\nPUT  after success  [TTL 90 days]" as dedupe #F9FBE7
    database "DEDUPE_KV" as dedupe_kv #E8F5E9
  }

  package "Handler Chain  (catalog-driven, ordered)" as chain_pkg #F9FBE7 {
    component "resolve_identity\n· upsert identity_links (alias per email / anon_id)\n· link anonymous_id → profile_id" as h1 #C8E6C9
    component "upsert_event_store\n· INSERT funnel_events (profile_id, tenant_id, product_code)" as h2 #C8E6C9
    component "enrich_attribution\n· SELECT fbp / fbc / client_ip from prior site events" as h3 #C8E6C9
    component "update_brevo_funnel\n· PATCH /contacts  (funnel step attrs + list membership)" as h4 #C8E6C9
    component "emit_tracking\n· POST sGTM endpoint\n· server_queue events: PURCHASE_APPROVED · BEGIN_CHECKOUT · <color:#6A1B9A>SIGN_UP</color>\n· <color:#2E7D32>skipped for delivery=both events (ex: GENERATE_LEAD)</color>" as h5 #C8E6C9
    component "call_product_api  [generic]\n· reads product_api from catalog event\n· HMAC-signed POST to external API" as h6 #C8E6C9
    component "send_template_email  [generic]\n· reads template_email from catalog event\n· POST /smtp/email (Brevo transactional)" as h7 #C8E6C9
    component "send_brevo_doi · send_cart_abandonment_email\ninvalidate_purchase_token · sync_brevo_segments" as h_etc #C8E6C9
  }
}

' ════════════════════════════════════════════════════════════════
'  LAYER 6 — Cloudflare Storage + Secrets
' ════════════════════════════════════════════════════════════════
package "Cloudflare Storage" as storage_pkg #E8F5E9 {
  database "IDENTITY_DB  (D1)\nidentity_links\n  tenant_id · profile_id\n  email_hash · anonymous_id\n  updated_at" as identity_db
  database "EVENT_STORE_DB  (D1)\nfunnel_events\n  event_id · profile_id · tenant_id\n  product_code · event_type\n  source · payload_json · occurred_at" as event_db
  database "IDENTITY_KV\ncheckout_recovery:<rid>\npurchase recovery tokens" as identity_kv
}

package "Cloudflare Secrets Store  (account-level)" as secrets_pkg #FFF3E0 {
  database "Secrets  (naming: {SECRET}_{TENANT}[_{PRODUCT}])\nBREVO_API_KEY_{TENANT}\nHOTMART_WEBHOOK_TOKEN_{TENANT}\nGA4_API_SECRET_{TENANT}  ·  GA4_MEASUREMENT_ID_{TENANT}\nMETA_CAPI_ACCESS_TOKEN_{TENANT}\nMETA_PIXEL_ID_{TENANT}_{PRODUCT}\nPLANOVOO_API_BASE_URL_{TENANT}\nPLANOVOO_HOOK_SECRET_{TENANT}\nSGTM_ENDPOINT_URL_{TENANT}\nADMIN_SECRET_{TENANT}" as secrets #FFE0B2
}

' ════════════════════════════════════════════════════════════════
'  LAYER 7 — External integrations
' ════════════════════════════════════════════════════════════════
package "Brevo  (ESP)" as brevo_pkg #EDE7F6 {
  component "Contacts API\n(DOI · attributes · lists · segments)" as brevo_contacts
  component "SMTP API\n(transactional emails)" as brevo_smtp
}

package "Tracking" as tracking_pkg #E1F5FE {
  component "sGTM  (shared Cloud Run)\n1 container — N custom domains\n─────────────────────────────────────────\nreceives from GTM Web (browser)\nreceives from funnel-dispatcher (server)\n─────────────────────────────────────────\nRouting via lookup tables:\n  <b>produto</b>  →  GA4 measurementId + apiSecret\n  <b>pixel_id</b>  →  Meta CAPI destination\n  tenant_id  →  credentials set" as sgtm  #B3E5FC
  component "GA4\nProperty  G-BQQB6X5XN1  (shared)\n─────────────────────────────────────────\n<b>Custom dimension  produto</b>  segments events:\n  produto=DECOLE_ESG_MENTORIA\n  produto=DECOLE_PLANOVOO\nMeasurement Protocol" as ga4   #B3E5FC
  component "Meta CAPI\nConversions API\n─────────────────────────────────────────\n<b>Per-product pixel IDs</b>:\n  ESG Mentoria  →  pixel_id=1329973348435032\n  Plano de Voo  →  pixel_id=2220600768748665\n(routed by sGTM lookup table)" as meta  #B3E5FC
}

component "Plano de Voo App\n(Next.js + PostgreSQL)\n/api/hooks/purchase · /refund · /protest" as planovoo_app #D5F5E3

' ════════════════════════════════════════════════════════════════
'  LAYER 8 — Backoffice
' ════════════════════════════════════════════════════════════════
package "Backoffice  (Cloudflare)" as bo_pkg #F3E5F5 {
  component "mkt-dashboard\n· User Journey by email (tenant-scoped)\n· GA4 + Meta daily metrics\n· auth ADMIN_SECRET_{TENANT}" as dashboard #E1BEE7
  component "dashboard-sync  (cron)\n· iterates catalog tenants × products\n· GA4 Data API → D1 ga4_daily_metrics\n· Meta Ads Insights → D1 meta_daily_metrics" as dash_sync #E1BEE7
}

' ════════════════════════════════════════════════════════════════
'  FLOWS — Browser / Site (tracking path)
' ════════════════════════════════════════════════════════════════

' User visits site
browser --> lp_esg     : "visit"
browser --> lp_pv      : "visit"

' Landing pages → dataLayer → GTM Web
lp_esg     --> gtm_web : "<color:#1565C0>page_view  dataLayer.push</color>\n<color:#1565C0>cta_click  dataLayer.push</color>\n<color:#2E7D32>generate_lead  dataLayer.push</color>"
lp_esg_doi --> gtm_web : "<color:#1565C0>page_view  dataLayer.push</color>"
lp_pv      --> gtm_web : "<color:#1565C0>page_view  dataLayer.push</color>\n<color:#1565C0>cta_click  dataLayer.push</color>\n<color:#2E7D32>generate_lead  dataLayer.push</color>"
lp_pv_doi  --> gtm_web : "<color:#1565C0>page_view  dataLayer.push</color>"

' GTM Web → sGTM (all events via GA4 + Meta Pixel tags)
gtm_web --> sgtm : "<color:#1565C0>page_view · cta_click</color>\n<color:#2E7D32>generate_lead</color>\n<color:#6A1B9A>begin_checkout</color>\n(GA4 tag + Meta Pixel tag)"

' ════════════════════════════════════════════════════════════════
'  FLOWS — Server-side funnel path (ingress → queue → dispatcher)
' ════════════════════════════════════════════════════════════════

' Hotmart → ingress
hotmart --> hw : "POST /webhooks/v1/hotmart\n(payload + X-HOTMART-HOTTOK)"

' Browser → ingress (form submits / server events)
lp_esg     --> pw : "<color:#2E7D32>generate_lead form submit</color>"
lp_pv      --> pw : "<color:#2E7D32>generate_lead form submit</color>"
browser    --> lr : "DOI confirm click  (<color:#2E7D32>/decole-esg/signup · /plano-de-voo/signup</color>)\ncheckout link click  (<color:#6A1B9A>BEGIN_CHECKOUT</color>)"
lr         --> browser : "302 → Hotmart checkout / confirmacao.html"
lr         --> lp_esg_doi : "(redirect DOI ESG)"
lr         --> lp_pv_doi  : "(redirect DOI Plano de Voo)"

' Catalog lookups
hw  ..> catalog : "resolve tenant · product\nvalidate token secret name"
fw  ..> catalog : "CORS · appWebhooks · HMAC"
lr  ..> catalog : "route path → product\ncheckout URL"
pw  ..> catalog : "DOI config · Brevo list ID\ntemplate ID"

' Secrets lookups
hw  ..> secrets : "HOTMART_WEBHOOK_TOKEN_{TENANT}"
fw  ..> secrets : "{TENANT}_HOOK_SECRET"

' Publish to Queue
hw --> q : "<color:#6A1B9A>PURCHASE_APPROVED · PURCHASE_*</color>\nPURCHASE_OUT_OF_SHOPPING_CART\n..."
pw --> q : "<color:#2E7D32>GENERATE_LEAD  (delivery=both)</color>"
lr --> q : "<color:#6A1B9A>BEGIN_CHECKOUT  (server_queue)</color>\n<color:#2E7D32>SIGN_UP  (server_queue — DOI links)</color>"
q  ..> dlq : "retries exhausted"

' Queue → Dispatcher
q --> resolve : "consume batch"
resolve ..> catalog : "resolveCatalogEvent → chain[ ]"
resolve --> dedupe
dedupe  ..> dedupe_kv : "GET / PUT"
dedupe  --> h1

' Handler chain
h1 --> h2
h2 --> h3
h3 --> h4
h4 --> h5
h5 --> h6
h6 --> h7

' Handler side effects → storage
h1 ..> identity_db : "upsert identity_links\n(alias rows per email + anon_id)"
h1 ..> identity_kv : "recovery tokens"
h2 ..> event_db    : "INSERT funnel_events"
h3 ..> event_db    : "SELECT fbp/fbc/client_ip\nfrom prior site events"

' Handler side effects → integrations
h4  ..> brevo_contacts : "PATCH /contacts\n(funnel step + attrs)"
h5  ..> sgtm           : "<color:#6A1B9A>POST event payload\n(PURCHASE_APPROVED · BEGIN_CHECKOUT)</color>"
h6  ..> planovoo_app   : "POST /api/hooks/purchase\n(HMAC-SHA256)"
h7  ..> brevo_smtp     : "POST /smtp/email\n(template_id + params)"
h_etc ..> brevo_contacts : "DOI · segments"
h_etc ..> brevo_smtp     : "cart abandonment"
h_etc ..> identity_kv    : "DELETE token\n(refund / cancel)"

' Dispatcher reads secrets
disp_pkg ..> secrets : "BREVO_API_KEY_{TENANT}\nGA4_API_SECRET_{TENANT}\nMETA_CAPI_ACCESS_TOKEN_{TENANT}\nSGTM_ENDPOINT_URL_{TENANT}\n..."

' sGTM → downstream
sgtm --> ga4  : "Measurement Protocol\n(page_view · generate_lead · sign_up\ncta_click · purchase)"
sgtm --> meta : "Conversions API\n(PageView · Lead · Purchase\nCompleteRegistration)"

' Backoffice
dash_sync ..> ga4      : "GA4 Data API  (daily cron)"
dash_sync ..> meta     : "Meta Ads Insights API"
dash_sync ..> event_db : "INSERT ga4_daily_metrics\nmeta_daily_metrics  (tenant_id)"
dash_sync ..> catalog  : "iterate tenants · products"
dashboard ..> identity_db : "findProfileByEmailHash\n(tenant-scoped)"
dashboard ..> event_db    : "SELECT funnel_events by profile_id"
dashboard ..> secrets     : "ADMIN_SECRET_{TENANT}"

' ════════════════════════════════════════════════════════════════
'  NOTES
' ════════════════════════════════════════════════════════════════
note right of catalog
  <b>Catalog-driven (G.1)</b>
  Workers know CONVENTIONS, not TENANTS.
  Zero runtime config fetches — bundled at build.
  New tenant = catalog entry + secrets + DNS.
  Zero worker code changes.
  ─────────────────────────────────
  <b>Tracking differentiation per product:</b>
  products.{code}.tracking.gtm
    .differentiationKey   = "produto"
    .differentiationValue = "DECOLE_ESG_MENTORIA"
                          | "DECOLE_PLANOVOO"
  products.{code}.tracking.ga4
    .differentiationKeys.produto  = same value
    .measurementId  = G-BQQB6X5XN1  (shared)
  products.{code}.tracking.metaPixel
    .differentiationKey   = "pixel_id"
    .pixelId  = 1329973348435032   (ESG)
              | 2220600768748665   (Plano de Voo)
end note

note bottom of dedupe_kv
  <b>DEDUPE key format</b>
  tenant:product:event_id:handler
  ex: decole:DECOLE_PLANOVOO:<uuid>:call_product_api
  ──────────────────────────────
  Idempotent replay:
  cleanup-transaction.mjs --replay --event-id <uuid>
end note

note right of sgtm
  <b>Shared sGTM  (Model B)</b>
  1 Cloud Run container
  N custom domains (one per tenant)
  sgtm.decolesuacarreiraesg.com.br
  ─────────────────────────────────
  Lookup tables route by:
  · <b>produto</b>  →  GA4 measurementId + api_secret
  · <b>pixel_id</b>  →  Meta CAPI pixel destination
  · tenant_id  →  credentials set
  ─────────────────────────────────
  Sources:
  · GTM Web tags (browser events)
    → carry  produto=DECOLE_*  param
  · funnel-dispatcher emit_tracking
    (server_queue events only)
    → carry  produto  from catalog
    tracking.ga4.differentiationKeys
end note

note bottom of h5
  <b>emit_tracking skipped for delivery=both</b>
  GENERATE_LEAD tracked via GTM Web → sGTM (browser path).
  Server chain omits emit_tracking para evitar dupla contagem.
  ──────────────────────────────────────
  <b>SIGN_UP (DOI confirmation)</b>
  delivery=server_queue desde 2026-05-27.
  Emitido por links-redirect (nao browser).
  chain: resolve_identity → upsert_event_store
       → enrich_attribution → update_brevo_funnel
       → emit_tracking → sGTM (CompleteRegistration)
  Paginas /confirmacao.html: sem conversao browser-side.
end note

@enduml
